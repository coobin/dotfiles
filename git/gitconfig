# vim: ft=gitconfig

[user]
	name = Kay
	email = hekaixuan@outlook.com
	signingkey = ~/.ssh/macmini.pub

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true

[tag]
	gpgsign = true

[alias]
	st = status
	co = checkout
	wtf = "!git commit -m\"$(curl -L -s https://commitlog.wolege.ca/)"\"

[pager]
	diff =
	branch = false

[core]
	editor = nvim
	excludesfile = ~/.gitignore

[help]
	autocorrect = 1

[color]
	ui = true

[push]
	default = current

[include]
	path = ~/.gitconfig.local
