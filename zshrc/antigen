# vim: ft=zsh
# setup homebrew env

[ -f "/opt/homebrew/bin/brew" ] && BREW="/opt/homebrew/bin/brew"
[ -f "/usr/local/bin/brew" ] && BREW="/usr/local/bin/brew"

[ -z "$HOMEBREW_PREFIX" ] && HOMEBREW_PREFIX="$($BREW --prefix)"

# setup antigen
source "$HOMEBREW_PREFIX/share/antigen/antigen.zsh"

builtin_fpath=($fpath[@])

# oh-my-zsh vars
CASE_SENSITIVE="true"

# antigen setup
antigen use oh-my-zsh

antigen bundle autojump
antigen bundle brew
antigen bundle fzf
antigen bundle git
antigen bundle golang

antigen bundle zsh-users/zsh-completions src
antigen bundle zsh-users/zsh-syntax-highlighting
antigen theme denysdovhan/spaceship-prompt spaceship

antigen apply

# env setup
[ -f "$HOME/.extra.zsh" ] && source "$HOME/.extra.zsh"

export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"

export GOPATH="$HOME/.go"
export PATH="$PATH:$GOPATH/bin"

export CARGOPATH="$HOME/.cargo"
export PATH="$PATH:$CARGOPATH/bin:"

# pyenv setup
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$($HOMEBREW_PREFIX/bin/pyenv init --path)"

# direnv setup
eval "$(direnv hook zsh)"

# proxy setup
if nc -z 10.0.0.2 1069 2>/dev/null; then
  export https_proxy="http://10.0.0.2:1069"
  export http_proxy="http://10.0.0.2:1069"
  export all_proxy="socks5://10.0.0.2:1069"
fi

# aliases
alias ll="ls -lahF --color "

ytdl-best() { yt-dlp -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/bestvideo+bestaudio/best' --merge-output-format mp4 "$1"; }
ytdl-mp3() {
  if [ -z "$1" ]; then
    echo "Usage: ytdl-mp3 <youtube-url>"
    return 1
  fi

  yt-dlp \
    -f "bestaudio" \
    --extract-audio \
    --audio-format mp3 \
    --audio-quality 0 \
    --embed-thumbnail \
    --continue \
    "$1"
}

# theme config
SPACESHIP_PROMPT_ASYNC="true"
SPACESHIP_PROMPT_ORDER=(
  user          # Username section
  dir           # Current directory section
  host          # Hostname section
  git           # Git section (git_branch + git_status)
  package       # Package version
  golang        # Go section
  venv          # virtualenv section
  line_sep      # Line break
  exit_code     # Exit code section
  char          # Prompt character
)
